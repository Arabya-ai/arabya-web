{"id":101,"slug":"turkish","resourceId":77,"nameAr":"التركية — ديانت","nameEn":"Turkish (Diyanet)","lang":"tr","source":"Quran.com API v4","sourceUrl":"https://quran.com","verses":[{"verseNumber":1,"verseKey":"101:1","text":"Gürültü koparacak olan"},{"verseNumber":2,"verseKey":"101:2","text":"Nedir o gürültü koparacak olan?"},{"verseNumber":3,"verseKey":"101:3","text":"O gürültü koparacak olanın ne olduğunu sen bilir misin?"},{"verseNumber":4,"verseKey":"101:4","text":"O gün insanlar, ateş etrafında çırpınıp dökülen pervaneye dönecekler."},{"verseNumber":5,"verseKey":"101:5","text":"Dağlar, atılmış renkli yüne benzeyecekler."},{"verseNumber":6,"verseKey":"101:6","text":"Ama tartıları ağır gelen kimse hoş bir hayat içinde olacaktır."},{"verseNumber":7,"verseKey":"101:7","text":"Ama tartıları ağır gelen kimse hoş bir hayat içinde olacaktır."},{"verseNumber":8,"verseKey":"101:8","text":"Tartıları hafif gelenler ise,"},{"verseNumber":9,"verseKey":"101:9","text":"Onların yeri bir çukurdur."},{"verseNumber":10,"verseKey":"101:10","text":"O çukurun ne olduğunu sen bilir misin?"},{"verseNumber":11,"verseKey":"101:11","text":"O, kızgın bir ateştir."}]}