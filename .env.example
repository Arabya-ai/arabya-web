# Auth.js / NextAuth — لا ترفع القيم الحقيقية إلى Git
# انسخ هذا الملف إلى .env.local واملأ القيم (انظر docs/platform/accounts-owner-guide-ar.md)

# مفتاح عشوائي لحماية الجلسات (ولّده مرة واحدة: openssl rand -base64 32)
AUTH_SECRET=

# من Google Cloud → Credentials → OAuth client
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# بريد Gmail للمدير (يمكن أكثر من بريد مفصول بفاصلة)
ARABYA_ADMIN_EMAILS=
