{"id":1,"slug":"turkish","resourceId":77,"nameAr":"التركية — ديانت","nameEn":"Turkish (Diyanet)","lang":"tr","source":"Quran.com API v4","sourceUrl":"https://quran.com","verses":[{"verseNumber":1,"verseKey":"1:1","text":"Rahman ve Rahim olan Allah'ın adıyla:"},{"verseNumber":2,"verseKey":"1:2","text":"Hamd, Alemlerin Rabbi Allah'a mahsustur."},{"verseNumber":3,"verseKey":"1:3","text":"O Rahman ve Rahim'dir,"},{"verseNumber":4,"verseKey":"1:4","text":"Din Gününün sahibidir."},{"verseNumber":5,"verseKey":"1:5","text":"Ancak Sana kulluk eder ve yalnız Senden yardım dileriz."},{"verseNumber":6,"verseKey":"1:6","text":"Bizi doğru yola eriştir."},{"verseNumber":7,"verseKey":"1:7","text":"Nimete erdirdiğin kimselerin yoluna; gazaba uğrayanların, ya da sapıtanların yoluna değil."}]}