{"id":107,"slug":"indonesian","resourceId":33,"nameAr":"الإندونيسية","nameEn":"Indonesian Ministry of Religious Affairs","lang":"id","source":"Quran.com API v4","sourceUrl":"https://quran.com","verses":[{"verseNumber":1,"verseKey":"107:1","text":"Tahukah kamu (orang) yang mendustakan agama?"},{"verseNumber":2,"verseKey":"107:2","text":"Maka itulah orang yang menghardik anak yatim,"},{"verseNumber":3,"verseKey":"107:3","text":"dan tidak mengajak memberi makan orang miskin."},{"verseNumber":4,"verseKey":"107:4","text":"Maka celakalah orang yang salat,"},{"verseNumber":5,"verseKey":"107:5","text":"(yaitu) orang-orang yang lalai terhadap salatnya, 1"},{"verseNumber":6,"verseKey":"107:6","text":"yang berbuat riya`, 1"},{"verseNumber":7,"verseKey":"107:7","text":"dan enggan (memberikan) bantuan. 1"}]}