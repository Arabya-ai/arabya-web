{"id":102,"slug":"hamidullah-fr","resourceId":31,"nameAr":"حميد الله (فرنسي)","nameEn":"Muhammad Hamidullah","lang":"fr","source":"Quran.com API v4","sourceUrl":"https://quran.com","verses":[{"verseNumber":1,"verseKey":"102:1","text":"La course aux richesses vous distrait,"},{"verseNumber":2,"verseKey":"102:2","text":"jusqu’à ce que vous visitiez les tombes 1."},{"verseNumber":3,"verseKey":"102:3","text":"Mais non ! Vous saurez bientôt !"},{"verseNumber":4,"verseKey":"102:4","text":"(Encore une fois) ! Vous saurez bientôt !"},{"verseNumber":5,"verseKey":"102:5","text":"Sûrement ! Si vous saviez de science certaine 1."},{"verseNumber":6,"verseKey":"102:6","text":"Vous verrez, certes, la Fournaise."},{"verseNumber":7,"verseKey":"102:7","text":"Puis, vous la verrez certes, avec l’œil de certitude."},{"verseNumber":8,"verseKey":"102:8","text":"Puis, assurément, vous serez interrogés, ce jour-là, sur les délices."}]}