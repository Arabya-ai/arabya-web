{"id":112,"slug":"junagarhi-ur","resourceId":54,"nameAr":"جوناغري (أردو)","nameEn":"Maulana Muhammad Junagarhi","lang":"ur","source":"Quran.com API v4","sourceUrl":"https://quran.com","verses":[{"verseNumber":1,"verseKey":"112:1","text":"آپ کہہ دیجئے کہ وه اللہ تعالیٰ ایک (ہی) ہے."},{"verseNumber":2,"verseKey":"112:2","text":"اللہ تعالیٰ بے نیاز ہے.1"},{"verseNumber":3,"verseKey":"112:3","text":"نہ اس سے کوئی پیدا ہوا نہ وه کسی سے پیدا ہوا.1"},{"verseNumber":4,"verseKey":"112:4","text":"اور نہ کوئی اس کا ہمسر ہے.1"}]}