{"id":104,"slug":"hamidullah-fr","resourceId":31,"nameAr":"حميد الله (فرنسي)","nameEn":"Muhammad Hamidullah","lang":"fr","source":"Quran.com API v4","sourceUrl":"https://quran.com","verses":[{"verseNumber":1,"verseKey":"104:1","text":"Malheur à tout calomniateur diffamateur,"},{"verseNumber":2,"verseKey":"104:2","text":"qui amasse une fortune et la compte,"},{"verseNumber":3,"verseKey":"104:3","text":"pensant que sa fortune l’immortalisera."},{"verseNumber":4,"verseKey":"104:4","text":"Mais non ! Il sera certes, jeté dans la Hutamah 1."},{"verseNumber":5,"verseKey":"104:5","text":"Et qui te dira ce qu’est la Hutamah ?"},{"verseNumber":6,"verseKey":"104:6","text":"Le Feu attisé d’Allah."},{"verseNumber":7,"verseKey":"104:7","text":"qui monte jusqu’aux cœurs."},{"verseNumber":8,"verseKey":"104:8","text":"Il se refermera sur eux,"},{"verseNumber":9,"verseKey":"104:9","text":"en colonnes (de flammes) étendues."}]}