{"id":114,"slug":"indonesian","resourceId":33,"nameAr":"الإندونيسية","nameEn":"Indonesian Ministry of Religious Affairs","lang":"id","source":"Quran.com API v4","sourceUrl":"https://quran.com","verses":[{"verseNumber":1,"verseKey":"114:1","text":"Katakanlah, \"Aku berlindung kepada Tuhannya manusia,"},{"verseNumber":2,"verseKey":"114:2","text":"Raja manusia,"},{"verseNumber":3,"verseKey":"114:3","text":"sembahan manusia,"},{"verseNumber":4,"verseKey":"114:4","text":"dari kejahatan (bisikan) setan yang bersembunyi,"},{"verseNumber":5,"verseKey":"114:5","text":"yang membisikkan (kejahatan) ke dalam dada manusia,"},{"verseNumber":6,"verseKey":"114:6","text":"dari (golongan) jin dan manusia.\""}]}