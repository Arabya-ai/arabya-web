{"id":94,"slug":"indonesian","resourceId":33,"nameAr":"الإندونيسية","nameEn":"Indonesian Ministry of Religious Affairs","lang":"id","source":"Quran.com API v4","sourceUrl":"https://quran.com","verses":[{"verseNumber":1,"verseKey":"94:1","text":"Bukankah kami telah melapangkan dadamu (Muhammad)?"},{"verseNumber":2,"verseKey":"94:2","text":"dan kami pun telah menurunkan beban darimu, 1"},{"verseNumber":3,"verseKey":"94:3","text":"yang memberatkan punggungmu,"},{"verseNumber":4,"verseKey":"94:4","text":"dan kami tinggikan sebutan (nama)mu 1 bagimu."},{"verseNumber":5,"verseKey":"94:5","text":"Maka sesungguhnya bersama kesulitan ada kemudahan,"},{"verseNumber":6,"verseKey":"94:6","text":"sesungguhnya bersama kesulitan ada kemudahan."},{"verseNumber":7,"verseKey":"94:7","text":"Maka apabila engkau telah selesai (dari suatu urusan), tetaplah bekerja keras (untuk urusan yang lain), 1"},{"verseNumber":8,"verseKey":"94:8","text":"dan hanya kepada Tuhanmulah engkau berharap."}]}