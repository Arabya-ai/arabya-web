{"id":101,"slug":"junagarhi-ur","resourceId":54,"nameAr":"جوناغري (أردو)","nameEn":"Maulana Muhammad Junagarhi","lang":"ur","source":"Quran.com API v4","sourceUrl":"https://quran.com","verses":[{"verseNumber":1,"verseKey":"101:1","text":"کھڑکھڑا دینے والی.*"},{"verseNumber":2,"verseKey":"101:2","text":"کیا1 ہے وه کھڑکھڑا دینے والی."},{"verseNumber":3,"verseKey":"101:3","text":"تجھے کیا معلوم کہ وه کھڑ کھڑا دینے والی کیا ہے."},{"verseNumber":4,"verseKey":"101:4","text":"جس دن انسان بکھرے ہوئے پروانوں کی طرح ہو جائیں گے.1"},{"verseNumber":5,"verseKey":"101:5","text":"اور پہاڑ دھنے ہوئے رنگین اون کی طرح ہو جائیں گے.1"},{"verseNumber":6,"verseKey":"101:6","text":"پھر جس کے پلڑے بھاری ہوں گے.1"},{"verseNumber":7,"verseKey":"101:7","text":"وه تو دل پسند آرام کی زندگی میں ہوگا.1"},{"verseNumber":8,"verseKey":"101:8","text":"اور جس کے پلڑے ہلکے ہوں گے.1"},{"verseNumber":9,"verseKey":"101:9","text":"اس کا ٹھکانا ہاویہ ہے.1"},{"verseNumber":10,"verseKey":"101:10","text":"تجھے کیا معلوم کہ وه کیا ہے.1"},{"verseNumber":11,"verseKey":"101:11","text":"وه تند وتیز آگ (ہے).1"}]}