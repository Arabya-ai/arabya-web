{"id":109,"slug":"indonesian","resourceId":33,"nameAr":"الإندونيسية","nameEn":"Indonesian Ministry of Religious Affairs","lang":"id","source":"Quran.com API v4","sourceUrl":"https://quran.com","verses":[{"verseNumber":1,"verseKey":"109:1","text":"Katakanlah (Muhammad), \"Wahai orang-orang kafir!"},{"verseNumber":2,"verseKey":"109:2","text":"aku tidak akan menyembah apa yang kamu sembah,"},{"verseNumber":3,"verseKey":"109:3","text":"dan kamu bukan penyembah apa yang aku sembah,"},{"verseNumber":4,"verseKey":"109:4","text":"dan aku tidak pernah menjadi penyembah apa yang kamu sembah,"},{"verseNumber":5,"verseKey":"109:5","text":"dan kamu tidak pernah (pula) menjadi penyembah apa yang aku sembah."},{"verseNumber":6,"verseKey":"109:6","text":"Untukmu agamamu, dan untukku agamaku.\""}]}