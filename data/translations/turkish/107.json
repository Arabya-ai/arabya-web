{"id":107,"slug":"turkish","resourceId":77,"nameAr":"التركية — ديانت","nameEn":"Turkish (Diyanet)","lang":"tr","source":"Quran.com API v4","sourceUrl":"https://quran.com","verses":[{"verseNumber":1,"verseKey":"107:1","text":"Dini yalan sayanı gördün mü?"},{"verseNumber":2,"verseKey":"107:2","text":"Öksüzü kakıştıran, yoksulu doyurmaya yanaşmayan kimse işte odur."},{"verseNumber":3,"verseKey":"107:3","text":"Öksüzü kakıştıran, yoksulu doyurmaya yanaşmayan kimse işte odur."},{"verseNumber":4,"verseKey":"107:4","text":"Vay o namaz kılanların haline ki:"},{"verseNumber":5,"verseKey":"107:5","text":"Onlar kıldıkları namazdan gafildirler."},{"verseNumber":6,"verseKey":"107:6","text":"Onlar gösteriş yaparlar."},{"verseNumber":7,"verseKey":"107:7","text":"Onlar basit şeyleri dahi vermezler."}]}