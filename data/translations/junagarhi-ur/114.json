{"id":114,"slug":"junagarhi-ur","resourceId":54,"nameAr":"جوناغري (أردو)","nameEn":"Maulana Muhammad Junagarhi","lang":"ur","source":"Quran.com API v4","sourceUrl":"https://quran.com","verses":[{"verseNumber":1,"verseKey":"114:1","text":"آپ کہہ دیجئے! کہ میں لوگوں کے پروردگار کی پناه میں آتا ہوں.1"},{"verseNumber":2,"verseKey":"114:2","text":"لوگوں کے مالک کی1 (اور)."},{"verseNumber":3,"verseKey":"114:3","text":"لوگوں کے معبود کی (پناه میں).1"},{"verseNumber":4,"verseKey":"114:4","text":"وسوسہ ڈالنے والے پیچھے ہٹ جانے والے کے شر سے.1"},{"verseNumber":5,"verseKey":"114:5","text":"جو لوگوں کے سینوں میں وسوسہ ڈالتا ہے."},{"verseNumber":6,"verseKey":"114:6","text":"(خواه) وه جن میں سے ہو یا انسان میں سے.1"}]}