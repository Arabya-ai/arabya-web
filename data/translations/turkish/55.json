{"id":55,"slug":"turkish","resourceId":77,"nameAr":"التركية — ديانت","nameEn":"Turkish (Diyanet)","lang":"tr","source":"Quran.com API v4","sourceUrl":"https://quran.com","verses":[{"verseNumber":1,"verseKey":"55:1","text":"Rahman olan Allah Kuran'ı öğretti;"},{"verseNumber":2,"verseKey":"55:2","text":"Rahman olan Allah Kuran'ı öğretti;"},{"verseNumber":3,"verseKey":"55:3","text":"İnsanı yarattı, ona konuşmayı öğretti."},{"verseNumber":4,"verseKey":"55:4","text":"İnsanı yarattı, ona konuşmayı öğretti."},{"verseNumber":5,"verseKey":"55:5","text":"Güneş ve ayın hareketleri bir hesaba göredir."},{"verseNumber":6,"verseKey":"55:6","text":"Bitkiler ve ağaçlar O'nun buyruğuna boyun eğerler."},{"verseNumber":7,"verseKey":"55:7","text":"O, göğü yükseltmiştir; tartıyı koymuştur."},{"verseNumber":8,"verseKey":"55:8","text":"Artık tartıda tecavüz etmeyin."},{"verseNumber":9,"verseKey":"55:9","text":"Tartmayı doğru yapın, tartıyı eksik tutmayın."},{"verseNumber":10,"verseKey":"55:10","text":"Allah, yeri yaratıkları için meydana getirmiştir."},{"verseNumber":11,"verseKey":"55:11","text":"Orada meyveler, salkımlı hurma ağaçları, kabuklu taneler, güzel kokulu otlar vardır."},{"verseNumber":12,"verseKey":"55:12","text":"Orada meyveler, salkımlı hurma ağaçları, kabuklu taneler, güzel kokulu otlar vardır."},{"verseNumber":13,"verseKey":"55:13","text":"Ey insanlar ve cinler! Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız?"},{"verseNumber":14,"verseKey":"55:14","text":"O, insanı pişmiş çamur gibi kuru balçıktan yaratmıştır."},{"verseNumber":15,"verseKey":"55:15","text":"Cinleri de yalın bir alevden yaratmıştır."},{"verseNumber":16,"verseKey":"55:16","text":"Öyleyken; Rabbinizin nimetlerinden hangisini yalanlarsınız?"},{"verseNumber":17,"verseKey":"55:17","text":"O, iki doğunun Rabbidir, iki batının Rabbidir."},{"verseNumber":18,"verseKey":"55:18","text":"Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız?"},{"verseNumber":19,"verseKey":"55:19","text":"Acı ve tatlı sulu iki denizi birbirine kavuşmamak üzere salıvermiştir."},{"verseNumber":20,"verseKey":"55:20","text":"Aralarında bir engel vardır; birbirinin sınırını aşamazlar."},{"verseNumber":21,"verseKey":"55:21","text":"Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız?"},{"verseNumber":22,"verseKey":"55:22","text":"Bu iki denizden de inci ve mercan çıkar."},{"verseNumber":23,"verseKey":"55:23","text":"Öyleyken Rabbinizin nimetlerinden hangisini yalanlarsınız?"},{"verseNumber":24,"verseKey":"55:24","text":"Denizde yürüyen dağlar gibi gemiler O'nundur."},{"verseNumber":25,"verseKey":"55:25","text":"Öyleyken Rabbinizin nimetlerinden hangisini yalanlarsınız?"},{"verseNumber":26,"verseKey":"55:26","text":"Yeryüzünde bulunan her şey fanidir."},{"verseNumber":27,"verseKey":"55:27","text":"Ancak, yüce ve cömert olan Rabbinin varlığı bakidir."},{"verseNumber":28,"verseKey":"55:28","text":"Öyleyken Rabbinizin nimetlerinden hangisini yalanlarsınız?"},{"verseNumber":29,"verseKey":"55:29","text":"Göklerde ve yerde olan kimseler her şeyi O'ndan isterler; O her an kainata tasarruf etmektedir."},{"verseNumber":30,"verseKey":"55:30","text":"Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız?"},{"verseNumber":31,"verseKey":"55:31","text":"Ey insan ve cin toplulukları! Sizin de hesabınızı ele alacağız."},{"verseNumber":32,"verseKey":"55:32","text":"Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız?"},{"verseNumber":33,"verseKey":"55:33","text":"Ey cin ve insan toplulukları! Göklerin ve yerin çevresini aşıp geçmeye gücünüz yetiyorsa geçin! Ama Allah'ın verdiği bir güç olmaksızın geçemezsiniz ki!"},{"verseNumber":34,"verseKey":"55:34","text":"Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız?"},{"verseNumber":35,"verseKey":"55:35","text":"Ey insanlar ve cinler! Üzerinize dumansız bir alev ve ateşsiz bir duman gönderilir de kurtulamazsınız."},{"verseNumber":36,"verseKey":"55:36","text":"Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız?"},{"verseNumber":37,"verseKey":"55:37","text":"Gök yarılıp da, gül gibi kızardığı, yağ gibi eridiği zaman haliniz nice olur?"},{"verseNumber":38,"verseKey":"55:38","text":"Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız?"},{"verseNumber":39,"verseKey":"55:39","text":"O gün ne insana ve ne cine suçu sorulur."},{"verseNumber":40,"verseKey":"55:40","text":"Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız?"},{"verseNumber":41,"verseKey":"55:41","text":"Suçlular simalarından tanınırlar da, alın saçlarından ve ayaklarından yakalanırlar."},{"verseNumber":42,"verseKey":"55:42","text":"Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız?"},{"verseNumber":43,"verseKey":"55:43","text":"İşte suçluların yalanladıkları cehennem budur."},{"verseNumber":44,"verseKey":"55:44","text":"Onlar, cehennem ateşiyle kaynar su arasında dolaşır dururlar."},{"verseNumber":45,"verseKey":"55:45","text":"Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız?"},{"verseNumber":46,"verseKey":"55:46","text":"Rabbine karşı durmaktan korkan kimseye iki cennet vardır."},{"verseNumber":47,"verseKey":"55:47","text":"Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız?"},{"verseNumber":48,"verseKey":"55:48","text":"Bu iki cennet türlü ağaçlarla doludur."},{"verseNumber":49,"verseKey":"55:49","text":"Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız?"},{"verseNumber":50,"verseKey":"55:50","text":"Bu cennetlerden akan iki kaynak vardır."},{"verseNumber":51,"verseKey":"55:51","text":"Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız?"},{"verseNumber":52,"verseKey":"55:52","text":"Bu cennetlerde türlü meyveden çift çift vardır."},{"verseNumber":53,"verseKey":"55:53","text":"Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız?"},{"verseNumber":54,"verseKey":"55:54","text":"Orada, örtüleri parlak atlastan yataklara yaslanırlar; iki cennetin meyvelerini de kolayca toplarlar."},{"verseNumber":55,"verseKey":"55:55","text":"Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız?"},{"verseNumber":56,"verseKey":"55:56","text":"Orada, bakışlarını yalnız eşlerine çevirmiş, daha önce ne insan ve ne de cinlerin dokunmuş olduğu eşler vardır."},{"verseNumber":57,"verseKey":"55:57","text":"Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız?"},{"verseNumber":58,"verseKey":"55:58","text":"Onlar yakut ve mercan gibidirler."},{"verseNumber":59,"verseKey":"55:59","text":"Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız?"},{"verseNumber":60,"verseKey":"55:60","text":"İyiliğin karşılığı ancak iyilik değil midir?"},{"verseNumber":61,"verseKey":"55:61","text":"Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız?"},{"verseNumber":62,"verseKey":"55:62","text":"Bu iki cennetten başka iki cennet daha vardır."},{"verseNumber":63,"verseKey":"55:63","text":"Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız?"},{"verseNumber":64,"verseKey":"55:64","text":"Renkleri koyu yeşildir."},{"verseNumber":65,"verseKey":"55:65","text":"Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız?"},{"verseNumber":66,"verseKey":"55:66","text":"İkisinde de durmadan fışkıran iki kaynak vardır."},{"verseNumber":67,"verseKey":"55:67","text":"Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız?"},{"verseNumber":68,"verseKey":"55:68","text":"İkisinde de türlü türlü meyveler, hurmalıklar ve nar ağaçları vardır."},{"verseNumber":69,"verseKey":"55:69","text":"Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız?"},{"verseNumber":70,"verseKey":"55:70","text":"Oralarda iyi huylu güzel kadınlar vardır."},{"verseNumber":71,"verseKey":"55:71","text":"Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız?"},{"verseNumber":72,"verseKey":"55:72","text":"Çadırlar içinde ceylan gözlüler vardır."},{"verseNumber":73,"verseKey":"55:73","text":"Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız?"},{"verseNumber":74,"verseKey":"55:74","text":"Onlara daha önce insan da, cin de dokunmamıştır."},{"verseNumber":75,"verseKey":"55:75","text":"Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız?"},{"verseNumber":76,"verseKey":"55:76","text":"Cennetlikler orada yeşil yastıklara ve harikulade işlemeli döşeklere yaslanırlar."},{"verseNumber":77,"verseKey":"55:77","text":"Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız?"},{"verseNumber":78,"verseKey":"55:78","text":"Büyük ve pek cömert olan Rabbinin adı ne yücedir!"}]}